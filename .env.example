# =========================================================================
# SoulSeer Backend - Environment Variables
# Copy this file to .env and fill in the SECRET values from your own
# Supabase / Stripe / Cloudflare / Redis / Cloudinary dashboards.
# NEVER commit a real .env file. This repo has GitHub secret-scanning
# push protection enabled.
# =========================================================================

# ---- App ----
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# ---- Supabase (public, safe to hardcode) ----
VITE_SUPABASE_URL=https://iznypsetnntofngglngk.supabase.co
SUPABASE_URL=https://iznypsetnntofngglngk.supabase.co
SUPABASE_JWKS_URL=https://iznypsetnntofngglngk.supabase.co/auth/v1/.well-known/jwks.json

# ---- Supabase (SECRET - obtain from Supabase dashboard, never commit real values) ----
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=

# ---- Stripe (SECRET) ----
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=

# ---- Cloudflare Realtime / TURN (SECRET except relay URL) ----
CLOUDFLARE_MOQ_RELAY_URL=draft-14.cloudflare.mediaoverquic.com
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TURN_SERVERS_API_KEY=
CLOUDFLARE_REALTIME_APP_ID=
CLOUDFLARE_REALTIME_TOKEN=
CLOUDFLARE_REALTIME_WEBHOOK_ID=
CLOUDFLARE_SERVERLESS_SFU=

# ---- Redis (username is non-secret, rest are SECRET) ----
REDIS_DB_USERNAME=default
REDIS_DB_HOST=
REDIS_DB_PASSWORD=
REDIS_DB_ENDPOINT=
REDIS_DB_PORT=

# ---- Cloudinary (bucket name non-secret, keys SECRET) ----
CLOUDINARY_BUCKET_NAME=SoulSeer
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET=

# ---- Community links (public) ----
VITE_FACEBOOK_GROUP_URL=https://www.facebook.com/groups/1392052298909213/?ref=share&mibextid=NSMWBT
VITE_DISCORD_URL=https://discord.com/invite/6NrBCNW2gA
